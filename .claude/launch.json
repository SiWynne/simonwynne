{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "simonwynne-site",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--prefix", "Projects/simonwynne/site"],
      "port": 3000
